#!/bin/bash

set -euo pipefail
cd "$(dirname "$0")/.." || exit 1
rm -f deploy/shutdown.xml

JAVA_OPTS=()
APP_OPTS=()

PID_FILE="jpos.pid"
USE_PID=true

for arg in "$@"; do
  case "$arg" in
    -D*|-X*|-agentlib:*|-javaagent:*|--add-opens=*|--add-exports=*|--enable-native-access=*|--sun-misc-unsafe-memory-access=*)
      JAVA_OPTS+=("$arg")
      ;;
    --pid=*)
      PID_FILE="${arg#--pid=}"
      ;;
    --no-pid)
      USE_PID=false
      ;;
    --debug)
      JAVA_OPTS+=("-agentlib:jdwp=transport=dt_socket,server=y,suspend=y,address=5005")
      ;;
    *)
      APP_OPTS+=("$arg")
      ;;
  esac
done

if $USE_PID; then
  if [ -f "$PID_FILE" ] && ps -p "$(cat "$PID_FILE")" > /dev/null 2>&1; then
    echo "Process $(cat "$PID_FILE") is running"
    exit 1
  fi
  rm -f "$PID_FILE"
fi

mkdir -p log

CMD=(
  java
  -server
  -Xmx4G
  --enable-native-access=ALL-UNNAMED
  --sun-misc-unsafe-memory-access=allow
  -Xlog:gc:log/gc.log
)

CMD+=( ${JAVA_OPTS[@]+"${JAVA_OPTS[@]}"} )

CMD+=(
  -jar
  @jarname@
)

if $USE_PID; then
  CMD+=( "--pid=$PID_FILE" )
fi

CMD+=( ${APP_OPTS[@]+"${APP_OPTS[@]}"} )

# printf '%q ' "${CMD[@]}"
# echo
exec "${CMD[@]}"

